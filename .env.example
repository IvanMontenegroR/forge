# ─────────────────────────────────────────────────────────────
# Variables del FRONTEND (públicas por diseño — se exponen en el bundle).
# La protección real son las políticas RLS de Supabase, NO el secreto.
# Copiá este archivo a `.env` y completá con los valores de tu proyecto.
# ─────────────────────────────────────────────────────────────

# Project URL (Supabase → Project Settings → API → Project URL)
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co

# Anon / public key (Supabase → Project Settings → API → anon public)
VITE_SUPABASE_ANON_KEY=eyJ...tu-anon-key...

# Nombre de la Edge Function del coach (default: coach)
VITE_COACH_FUNCTION=coach

# Nombre de la Edge Function que estima calorías por foto (default: analyze-meal)
VITE_MEAL_FUNCTION=analyze-meal

# ─────────────────────────────────────────────────────────────
# NUNCA pongas acá la API key de Claude ni la service_role key.
#   - ANTHROPIC_API_KEY  → va como secreto de la Edge Function (ver README).
#   - SUPABASE_SERVICE_ROLE_KEY → solo en tu terminal al correr el seed.
# ─────────────────────────────────────────────────────────────
